[global_config]
  borderless = True
[keybindings]
[profiles]
  [[default]]
    background_darkness = 0.88
    background_type = transparent
    font = JetBrains Mono 10
    scrollback_infinite = True
    use_system_font = False
[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      parent = ""
    [[[child1]]]
      type = Terminal
      parent = window0
